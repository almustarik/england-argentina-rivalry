---
import './FaceOff.css';

const players = [
	{
		side: 'arg',
		name: 'Lionel Messi',
		number: '10',
		role: 'Captain · Forward',
		line: 'The last dance goes on. Two assists in five late minutes turned the semi-final — one more game to make it back-to-back.',
		stats: ['2 assists in the semi-final', '8 goals — leads the Golden Boot race', '39 years young · one game left'],
	},
	{
		side: 'eng',
		name: 'Harry Kane',
		number: '9',
		role: 'Captain · Striker',
		line: 'England’s record scorer led them within five minutes of the final. The one medal that matters must wait again.',
		stats: ['6 goals this tournament', 'Level with Bellingham on six', 'So close in Atlanta'],
	},
];
---

<section class="section faceoff" id="faceoff">
	<div class="section-head">
		<span class="num">03</span>
		<h2>Two captains,<br />one cruel night</h2>
	</div>

	<div class="faceoff-grid">
		{players.map((p) => (
			<article class={`faceoff-card faceoff-card-${p.side}`}>
				<div class="faceoff-card-inner">
					<span class="faceoff-number display" aria-hidden="true">{p.number}</span>
					<h3 class="display">{p.name}</h3>
					<p class="faceoff-role mono">{p.role}</p>
					<p class="faceoff-line">{p.line}</p>
					<ul class="faceoff-stats mono">
						{p.stats.map((s) => <li>{s}</li>)}
					</ul>
				</div>
			</article>
		))}
		<span class="faceoff-vs display" aria-hidden="true">VS</span>
	</div>
</section>

<script>
	import './FaceOff.js';
</script>
