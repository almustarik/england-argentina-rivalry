---
import './Footer.css';
---

<footer class="footer">
	<div class="marquee" id="footer-marquee" aria-hidden="true">
		<div class="marquee-track">
			<span>
				Vamos Argentina <i class="sun">☀</i> ¡A la final! <i class="sun">★</i>
				Sunday · MetLife <i class="sun">☀</i> One more dance <i class="sun">★</i>
			</span>
		</div>
	</div>

	<div class="footer-inner">
		<p class="footer-big display">Five minutes<br />from silence,<br />ninety from glory.</p>
		<div class="footer-links mono">
			<a href="https://gsap.com/" target="_blank" rel="noopener">Animated with GSAP</a>
			<a href="https://astro.build/" target="_blank" rel="noopener">Built with Astro</a>
			<a href="https://webflow.com/" target="_blank" rel="noopener">Deployed on Webflow Cloud</a>
			<a href="https://codetv.dev/" target="_blank" rel="noopener">A CodeTV hackathon entry</a>
		</div>
		<p class="footer-note mono">
			Unofficial fan project for the Webflow × GSAP × CodeTV "best landing page" challenge.
			Not affiliated with FIFA, the AFA, or the FA. The result is real — the hype is ours.
		</p>
	</div>
</footer>

<script>
	import './Footer.js';
</script>
